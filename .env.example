# --- Database ---
# Used by the Prisma CLI (migrate/db push/generate). In production this is a normal
# postgres:// connection string (e.g. your Supabase connection string).
DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"

# Used by the app's PrismaClient at runtime via @prisma/adapter-pg. In production, set
# this to the same value as DATABASE_URL.
DIRECT_DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"

# --- Auth.js ---
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Must match the port `npm run dev` actually runs on (only 3000 if nothing else is
# using it) — this is used to build links in outgoing emails (e.g. notification alerts).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: enables "Sign in with Google". Leave unset to use email/password only.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Email ---
# "smtp" for local dev (Mailpit), "resend" for production.
EMAIL_PROVIDER="smtp"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="Nepali Community UK <no-reply@nepalicommunityuk.co.uk>"
# RESEND_API_KEY=
# The "from" address's domain must be verified in Resend (Domains tab) or every send
# will fail — this bit us once: a stale placeholder domain in SMTP_FROM's default
# silently broke all production email until the domain was corrected here.

# Address that receives Contact form submissions.
CONTACT_RECEIVER_EMAIL="sameerkhatiwada4@gmail.com"

# --- Storage (profile photos, listing images, admin uploads) ---
# "local" saves to public/uploads — dev only, does NOT persist on Vercel's serverless
# filesystem. Use "supabase" in production (Supabase Storage, bucket must be named
# "uploads" and set to public).
STORAGE_PROVIDER="local"
# SUPABASE_URL="https://your-project-ref.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
