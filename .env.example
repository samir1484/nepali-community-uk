# --- Database ---
# Used by the Prisma CLI (migrate/db push/generate). In production this is a normal
# postgres:// connection string (e.g. your Supabase connection string).
DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"

# Used by the app's PrismaClient at runtime via @prisma/adapter-pg. In production, set
# this to the same value as DATABASE_URL.
DIRECT_DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"

# --- Auth.js ---
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: enables "Sign in with Google". Leave unset to use email/password only.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Email ---
# "smtp" for local dev (Mailpit), "resend" for production.
EMAIL_PROVIDER="smtp"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="Nepali Community UK <no-reply@nepalicommunity.uk>"
# RESEND_API_KEY=

# Address that receives Contact form submissions.
CONTACT_RECEIVER_EMAIL="sameerkhatiwada4@gmail.com"

# --- Storage (admin image uploads) ---
# "local" saves to public/uploads. A Cloudinary/S3 adapter can be added later behind
# the same interface (src/lib/storage) without changing any calling code.
STORAGE_PROVIDER="local"
