// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum UserType {
  STUDENT
  EMPLOYEE
  EMPLOYER
  LANDLORD
  TENANT
  BUSINESS_OWNER
  VOLUNTEER
  OTHER
}

enum Interest {
  JOBS
  EVENTS
  ROOMS
  BLOGS
  NEWS
  HOUSING
  BUSINESS
  EDUCATION
  FESTIVALS
  TECHNOLOGY
  HEALTH
  SPORTS
  IMMIGRATION
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String?
  phone         String?
  address       String?
  location      String?
  occupation    String?
  userType      UserType  @default(OTHER)
  interests     Interest[]
  image         String?
  role          Role      @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  listings Listing[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

enum SectionType {
  HIGHLIGHT
  SHOWCASE
}

model HomeSection {
  id        String      @id @default(cuid())
  type      SectionType
  title     String
  caption   String?
  imageUrl  String?
  order     Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([type, isActive, order])
  @@map("home_sections")
}

enum ListingType {
  JOB
  ROOM
  EVENT
  VOLUNTEER
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Listing {
  id          String           @id @default(cuid())
  type        ListingType
  title       String
  description String
  location    String
  status      ModerationStatus @default(PENDING)
  details     Json             @default("{}")
  images      String[]         @default([])
  authorId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([type, status, location])
  @@map("listings")
}
